{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/custom-metadata.schema.json",
  "title": "Custom Skill Metadata",
  "description": "Schema for custom skill metadata.yaml files with relaxed category and slug validation.",
  "type": "object",
  "properties": {
    "category": {
      "type": "string"
    },
    "author": {
      "type": "string",
      "pattern": "^@[a-z][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 30
    },
    "cliDescription": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "usageGuidance": {
      "type": "string",
      "minLength": 10
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{7}$"
    },
    "updated": {
      "type": "string"
    },
    "forkedFrom": {
      "type": "object",
      "properties": {
        "skillId": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "contentHash": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      },
      "required": ["skillId", "contentHash", "date"],
      "additionalProperties": false
    },
    "domain": {
      "type": "string"
    },
    "custom": {
      "type": "boolean"
    }
  },
  "required": ["category", "author", "displayName", "cliDescription", "usageGuidance", "slug"]
}
