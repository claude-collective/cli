{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/metadata.schema.json",
  "title": "Skill Metadata",
  "description": "Schema for skill metadata.yaml files.",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "ai-infrastructure",
        "ai-observability",
        "ai-orchestration",
        "ai-patterns",
        "ai-provider",
        "api-analytics",
        "api-api",
        "api-auth",
        "api-baas",
        "api-cms",
        "api-commerce",
        "api-database",
        "api-email",
        "api-flags",
        "api-framework",
        "api-observability",
        "api-performance",
        "api-search",
        "api-vector-db",
        "cli-framework",
        "infra-ci-cd",
        "infra-config",
        "infra-platform",
        "meta-methodology",
        "meta-reviewing",
        "mobile-framework",
        "shared-monorepo",
        "shared-security",
        "shared-tooling",
        "web-accessibility",
        "web-animation",
        "web-client-state",
        "web-data-fetching",
        "web-error-handling",
        "web-file-upload",
        "web-files",
        "web-forms",
        "web-framework",
        "web-i18n",
        "web-meta-framework",
        "web-mocking",
        "web-performance",
        "web-pwa",
        "web-realtime",
        "web-routing",
        "web-server-state",
        "web-styling",
        "web-testing",
        "web-tooling",
        "web-ui-components",
        "web-utilities"
      ]
    },
    "author": {
      "type": "string",
      "pattern": "^@[a-z][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 30
    },
    "cliDescription": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "usageGuidance": {
      "type": "string",
      "minLength": 10
    },
    "slug": {
      "type": "string",
      "enum": [
        "angular-standalone",
        "anti-over-engineering",
        "api-performance",
        "auth-security",
        "axiom-pino-sentry",
        "better-auth-drizzle-hono",
        "cli-commander",
        "cli-reviewing",
        "context-management",
        "css-animations",
        "cva",
        "cypress-e2e",
        "date-fns",
        "drizzle",
        "error-boundaries",
        "expo",
        "express",
        "fastify",
        "file-upload-patterns",
        "framer-motion",
        "github-actions",
        "graphql-apollo",
        "graphql-urql",
        "hono",
        "image-handling",
        "improvement-protocol",
        "investigation-requirements",
        "jotai",
        "mobx",
        "msw",
        "native-js",
        "next-intl",
        "nextjs-app-router",
        "nextjs-server-actions",
        "ngrx-signalstore",
        "nuxt",
        "oclif-ink",
        "offline-first",
        "pinia",
        "playwright-e2e",
        "posthog-analytics",
        "posthog-flags",
        "prisma",
        "radix-ui",
        "react",
        "react-hook-form",
        "react-intl",
        "react-native",
        "react-query",
        "react-testing-library",
        "redux-toolkit",
        "remix",
        "research-methodology",
        "resend-react-email",
        "result-types",
        "reviewing",
        "scss-modules",
        "service-workers",
        "setup-axiom-pino-sentry",
        "setup-env",
        "setup-posthog",
        "setup-resend",
        "setup-tooling",
        "shadcn-ui",
        "socket-io",
        "solidjs",
        "sse",
        "storybook",
        "success-criteria",
        "swr",
        "tailwind",
        "tanstack-table",
        "trpc",
        "turborepo",
        "vee-validate",
        "view-transitions",
        "vitest",
        "vue-composition-api",
        "vue-i18n",
        "vue-test-utils",
        "web-accessibility",
        "web-performance",
        "websockets",
        "write-verification",
        "zod-validation",
        "zustand"
      ]
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{7}$"
    },
    "updated": {
      "type": "string"
    },
    "forkedFrom": {
      "type": "object",
      "properties": {
        "skillId": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "contentHash": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      },
      "required": ["skillId", "contentHash", "date"],
      "additionalProperties": false
    },
    "domain": {
      "type": "string"
    },
    "custom": {
      "type": "boolean"
    }
  },
  "required": ["category", "author", "displayName", "cliDescription", "usageGuidance", "slug"],
  "additionalProperties": false
}
