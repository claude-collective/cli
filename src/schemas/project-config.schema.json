{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/project-config.schema.json",
  "title": "Project Configuration",
  "description": "Schema for .claude-src/config.yaml consumer project files (name, agents, stack, skills).",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(ai|web|api|cli|mobile|infra|meta|shared|security)-.+-.+$"
      }
    },
    "author": {
      "type": "string"
    },
    "installMode": {
      "type": "string",
      "enum": ["local", "plugin"]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ai", "api", "cli", "infra", "meta", "mobile", "shared", "web"]
      }
    },
    "selectedAgents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stack": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string",
          "enum": [
            "ai-infrastructure",
            "ai-observability",
            "ai-orchestration",
            "ai-patterns",
            "ai-provider",
            "api-analytics",
            "api-api",
            "api-auth",
            "api-baas",
            "api-cms",
            "api-commerce",
            "api-database",
            "api-email",
            "api-flags",
            "api-framework",
            "api-observability",
            "api-performance",
            "api-search",
            "api-vector-db",
            "cli-framework",
            "infra-ci-cd",
            "infra-config",
            "infra-platform",
            "meta-methodology",
            "meta-reviewing",
            "mobile-framework",
            "shared-monorepo",
            "shared-security",
            "shared-tooling",
            "web-accessibility",
            "web-animation",
            "web-client-state",
            "web-data-fetching",
            "web-error-handling",
            "web-file-upload",
            "web-files",
            "web-forms",
            "web-framework",
            "web-i18n",
            "web-meta-framework",
            "web-mocking",
            "web-performance",
            "web-pwa",
            "web-realtime",
            "web-routing",
            "web-server-state",
            "web-styling",
            "web-testing",
            "web-tooling",
            "web-ui-components",
            "web-utilities"
          ]
        },
        "additionalProperties": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^(ai|web|api|cli|mobile|infra|meta|shared|security)-.+-.+$"
                },
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "preloaded": {
                      "type": "boolean"
                    },
                    "local": {
                      "type": "boolean"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": ["id"],
                  "additionalProperties": false
                }
              ]
            },
            {
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^(ai|web|api|cli|mobile|infra|meta|shared|security)-.+-.+$"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "preloaded": {
                        "type": "boolean"
                      },
                      "local": {
                        "type": "boolean"
                      },
                      "path": {
                        "type": "string"
                      }
                    },
                    "required": ["id"],
                    "additionalProperties": false
                  }
                ]
              }
            }
          ]
        }
      }
    },
    "source": {
      "type": "string"
    },
    "marketplace": {
      "type": "string"
    },
    "agentsSource": {
      "type": "string"
    }
  },
  "required": ["name", "agents", "skills", "installMode", "stack", "source"],
  "additionalProperties": false
}
